        $raw_date   = get_field('date_of_payment', $payment_id);     
        $method     = get_field('mode_of_payment', $payment_id);     
   
        $amount_val   = $amount ? floatval($amount) : 0.00;     
        $method_txt   = $method ? $method : 'Bank Transfer';     
         
        $tenant_name = 'Out of contract'; 
        if ($tenant_id) { 
            $tenant_post = get_post($tenant_id); 
            if ($tenant_post && $tenant_post->post_type === 'ef_tenant' && $tenant_post->post_status === 'publish') { 
                $tenant_name = $tenant_post->post_title; 
            } 
        } 
   
        $property_name = $tenant_id ? get_field('property_unit_name', $tenant_id) : '';     
        if (!$property_name) {     
            $property_name = 'Lakeside Residences';      
        }     
   
        if ($raw_date) {     
            $timestamp   = strtotime($raw_date);     
            $date_format = date('n/j/Y', $timestamp);     
            $iso_date    = date('Y-m-d', $timestamp); 
            $period_val  = date('Y-m', $timestamp);     
        } else {     
            $date_format = get_the_date('n/j/Y', $payment_id);     
            $iso_date    = get_the_date('Y-m-d', $payment_id); 
            $period_val  = get_the_date('Y-m', $payment_id);     
        }     
   
        if ($tenant_id && $tenant_name !== 'Out of contract' && !in_array($tenant_name, $unique_tenants)) {     
            $unique_tenants[] = $tenant_name;     
        }     
        if (!in_array($period_val, $unique_periods)) {     
            $unique_periods[] = $period_val;     
        }     
   
        $payments_dataset[] = [     
            'id'        => $payment_id,     
            'tenant'    => $tenant_name, 
            'tenant_id' => $tenant_id, 
            'property'  => $property_name,     
            'period'    => $period_val,     
            'method'    => $method_txt,     
            'date'      => $date_format, 
            'raw_date'  => $iso_date, 
            'amount'    => $amount_val     
        ];     
    }     
    wp_reset_postdata();     
}     
   
sort($unique_tenants);     
sort($unique_periods);     
   
$json_payload = json_encode($payments_dataset);     
