<script>     
const efLedgerSourcePayload = <?php echo $json_payload; ?>;     
   
const efGlobalLogoBase64 = "https://estateflow.digital/wp-content/uploads/2026/06/cropped-estate.png"     
   
function efProcessLedgerQueryMatrix() {     
    const queryStr = document.getElementById('efLedgerInputSearch').value.toLowerCase();     
    const selTenant = document.getElementById('efLedgerSelectTenant').value;     
    const selMethod = document.getElementById('efLedgerSelectMethod').value;     
    const selPeriod = document.getElementById('efLedgerSelectPeriod').value;     
   
    const outputBody = document.getElementById('efLedgerGridInjectionTarget');     
    const fallbackEl = document.getElementById('efLedgerDataEmptyState');     
   
    outputBody.innerHTML = '';     
    let matchCount = 0;     
    let revenueAccumulator = 0;     
   
    efLedgerSourcePayload.forEach(entry => {     
        const matchSearch = !queryStr ||      
                            entry.tenant.toLowerCase().includes(queryStr) ||      
                            entry.property.toLowerCase().includes(queryStr) ||      
                            entry.method.toLowerCase().includes(queryStr);     
   
        const matchTenant = !selTenant || entry.tenant === selTenant;     
        const matchMethod = !selMethod || entry.method === selMethod;     
        const matchPeriod = !selPeriod || entry.period === selPeriod;     
   
        if (matchSearch && matchTenant && matchMethod && matchPeriod) {     
            matchCount++;     
            revenueAccumulator += entry.amount;     
   
            const rowHtml = document.createElement('tr');     
            if (entry.tenant === 'Out of contract') {
                rowHtml.style.backgroundColor = '#ff9393';
            }
            rowHtml.innerHTML = `     
                <td class="ef-cell-bold-tenant">${efEscapeOutputChar(entry.tenant)}</td>     
                <td style="color: #475569;">${efEscapeOutputChar(entry.property)}</td>     
                <td><span class="ef-badge-pill-period">${efEscapeOutputChar(entry.period)}</span></td>     
                <td style="color: #475569;">${efEscapeOutputChar(entry.method)}</td>     
                <td style="color: #475569;">${efEscapeOutputChar(entry.date)}</td>     
                <td class="ef-cell-accent-currency-green">AED ${Number(entry.amount).toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})}</td>     
                <td style="text-align: right;">     
                    <button class="ef-btn-receipt-pdf-download" title="Download PDF" onclick='efDownloadReceipt(efLedgerSourcePayload.find(item => item.id === ${entry.id}))'>     
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:inline-block; vertical-align:middle; margin-top:-2px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>     
                    </button>     
                    <button class="ef-btn-row-action" title="Edit" onclick='efEditTransaction(${entry.id})'> 
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:inline-block; vertical-align:middle; margin-top:-2px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg> 
                    </button> 
                    <button class="ef-btn-row-action delete" title="Delete" onclick='efDeleteTransaction(${entry.id})'> 
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:inline-block; vertical-align:middle; margin-top:-2px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg> 
                    </button> 
                </td>     
            `;     
            outputBody.appendChild(rowHtml);     
        }     
    });     
   
    document.getElementById('efLedgerCounterDisplay').innerHTML = `${matchCount} results • <span>AED ${revenueAccumulator.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 0})}</span>`;     
    fallbackEl.style.display = (matchCount === 0) ? 'block' : 'none';     
}     
   
function efEscapeOutputChar(str) {     
    if (!str) return '';     
    return String(str)     
        .replace(/&/g, '&amp;')     
        .replace(/</g, '&lt;')     
        .replace(/>/g, '&gt;')     
        .replace(/"/g, '&quot;')     
        .replace(/'/g, '&#039;');     
}     
 
function efEditTransaction(id) { 
    const entry = efLedgerSourcePayload.find(item => item.id === id); 
    if (!entry) return; 
 
    document.getElementById('efModalTitle').innerText = 'Edit payment'; 
    document.getElementById('efSubmitBtn').innerText = 'Update payment'; 
    document.getElementById('ef_log_payment_id').value = entry.id; 
    document.getElementById('ef_log_tenant').value = entry.tenant_id; 
    document.getElementById('ef_log_amount').value = entry.amount; 
    document.getElementById('ef_log_method').value = entry.method; 
    document.getElementById('ef_log_period').value = entry.period; 
    document.getElementById('ef_log_date').value = entry.raw_date; 
 
    document.getElementById('efLogPaymentGlobalModal').style.display = 'flex'; 
} 
 
function efDeleteTransaction(id) { 
    if (confirm("are you sure you want delete this transaction it will be deleted forever")) { 
        var fd = new FormData(); 
        fd.append('action', 'ef_action_delete_payment_record'); 
        fd.append('nonce', document.getElementById('ef_table_nonce').value);
        fd.append('payment_id', id); 
 
        fetch('<?php echo admin_url('admin-ajax.php'); ?>', { method: 'POST', body: fd }) 
        .then(res => res.json()) 
        .then(res => { 
            if (res.success) { 
                window.location.reload(); 
            } else { 
                alert(res.data.message || 'Deletion failure.'); 
            } 
        }).catch(err => { alert('Database communication channel interrupted.'); }); 
    } 
} 
  
